# Vercel (frontend) environment variables
# Add these in Vercel Dashboard → Project → Settings → Environment Variables.
# Placeholders only — never commit real values.

# Clerk auth (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_test_here
CLERK_SECRET_KEY=sk_live_or_test_here

# Razorpay (required for Pro checkout)
# The key ID appears twice on purpose:
#  - NEXT_PUBLIC_RAZORPAY_KEY_ID is read by Razorpay Checkout in the browser
#    (key IDs are public by design — this exposure is intentional)
#  - RAZORPAY_KEY_ID is the server-only copy used by API routes, which never
#    read NEXT_PUBLIC_* values
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_or_live_here
RAZORPAY_KEY_ID=rzp_test_or_live_here
# The secret must never be exposed to the browser.
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Optional — FastAPI backend base. Defaults (in next.config.ts) to the Render
# service below. Set this only to override; must point at the LIVE backend.
# API_URL=https://minialaddin-d8oe.onrender.com
# NEXT_PUBLIC_SITE_URL=https://mini-aladding.vercel.app
