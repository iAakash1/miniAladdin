# Vercel Environment Variables Configuration
# Add these in your Vercel Dashboard → Settings → Environment Variables

# FRED API Key - Get a free one at: https://fred.stlouisfed.org/docs/api/api_key.html
# Leave empty to use demo mode with mock data
FRED_API_KEY=

# Optional: For enhanced features (not required for basic functionality)
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
# NEWSAPI_KEY=your_newsapi_key_here

# Note: The app will work in DEMO MODE without FRED_API_KEY
# Demo mode provides realistic mock data for testing and development
