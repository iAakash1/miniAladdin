# OmniSignal backend — copy to .env and fill in. Placeholders only; never
# commit real values (CI runs gitleaks on every push).

# Required: FRED macro data (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Optional: Alpha Vantage fundamentals + MACD (free tier: 25 req/day)
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Optional: NewsAPI premium headlines (falls back to Yahoo RSS without it)
# NEWSAPI_KEY=your_newsapi_key_here

# Optional: LLM explanations via Groq (free key: https://console.groq.com/keys)
# Without it, /api/research serves the engine's own rationale as fallback.
# GROQ_API_KEY=your_groq_key_here
# LLM_MODEL=openai/gpt-oss-120b
# LLM_TIMEOUT=8
# LLM_CACHE_TTL=300

# ── Provider layer (all optional — each vendor self-disables without its key;
#    yfinance and Yahoo RSS are keyless anchors, so every chain always resolves)
# Market data:    Polygon → TwelveData → FMP → MarketStack → yfinance
# POLYGON_API_KEY=your_polygon_key_here
# FINNHUB_API_KEY=your_finnhub_key_here
# TWELVEDATA_API_KEY=your_twelvedata_key_here
# FMP_API_KEY=your_fmp_key_here
# MARKETSTACK_API_KEY=your_marketstack_key_here
# News:           NewsAPI → GNews → Yahoo RSS → Tavily
# GNEWS_API_KEY=your_gnews_key_here
# Search:         Tavily → Exa
# TAVILY_API_KEY=your_tavily_key_here
# EXA_API_KEY=your_exa_key_here
# Per-vendor rate override (requests/minute), e.g.:
# PROVIDER_POLYGON_RPM=5

# Optional: CORS allowlist for the API (comma-separated)
# ALLOWED_ORIGINS=https://mini-aladding.vercel.app,http://localhost:3000

# Optional: log verbosity (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
